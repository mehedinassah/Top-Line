# ── Top-Line backend environment ──────────────────────────────
# Copy this file to `.env` and fill in real values. Never commit `.env`.

# --- Database (Supabase Postgres) ---
# From Supabase: Project Settings → Database → Connection info.
# Use the connection pooler host for app connections.
DB_HOST=db.xxxxxxxxxxxx.supabase.co
DB_PORT=5432
DB_NAME=postgres
DB_USER=postgres
DB_PASSWORD=your-supabase-db-password

# --- JWT ---
# Use a long random string (>= 64 chars) in production.
JWT_SECRET=change-me-to-a-long-random-secret-at-least-64-characters-long-000

# --- First admin account (seeded on startup) ---
ADMIN_EMAIL=admin@topline.com
ADMIN_PASSWORD=change-this-strong-password
ADMIN_NAME=Store Admin

# --- CORS: which frontend origins may call the API ---
CORS_ALLOWED_ORIGINS=http://localhost:3000
